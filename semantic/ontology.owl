<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/edurecommend#"
     xml:base="http://www.semanticweb.org/edurecommend"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

    <owl:Ontology rdf:about="http://www.semanticweb.org/edurecommend"/>

    <owl:Class rdf:about="#Usuario"/>
    <owl:Class rdf:about="#Contenido"/>
    <owl:Class rdf:about="#Categoria"/>
    <owl:Class rdf:about="#Recomendacion"/>
    <owl:Class rdf:about="#Interaccion"/>

    <owl:ObjectProperty rdf:about="#tieneInteres">
        <rdfs:domain rdf:resource="#Usuario"/>
        <rdfs:range rdf:resource="#Categoria"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#perteneceACategoria">
        <rdfs:domain rdf:resource="#Contenido"/>
        <rdfs:range rdf:resource="#Categoria"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#recomiendaContenido">
        <rdfs:domain rdf:resource="#Recomendacion"/>
        <rdfs:range rdf:resource="#Contenido"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#recomendadaPara">
        <rdfs:domain rdf:resource="#Recomendacion"/>
        <rdfs:range rdf:resource="#Usuario"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#realizadaPor">
        <rdfs:domain rdf:resource="#Interaccion"/>
        <rdfs:range rdf:resource="#Usuario"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#sobreContenido">
        <rdfs:domain rdf:resource="#Interaccion"/>
        <rdfs:range rdf:resource="#Contenido"/>
    </owl:ObjectProperty>

    <owl:DatatypeProperty rdf:about="#nombre">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#descripcion">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#nivel">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#url">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#fecha">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

</rdf:RDF>